{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hugr.dev/schemas/ask.schema.json",
  "title": "Ask",
  "description": "One question to a Hugr subagent (ARCHITECTURE §18.1). The wire form of hugr_agent::Ask.",
  "type": "object",
  "required": ["question"],
  "properties": {
    "question": {
      "type": "string",
      "description": "The question text — the only required field."
    },
    "trace_id": {
      "type": "string",
      "description": "Resume/fork anchor: run this ask as a follow-up of the identified stored trace. Absent = fresh root trace."
    },
    "blobs": {
      "type": "array",
      "description": "Inbound files, materialized into the scratchpad before the turn.",
      "items": { "$ref": "#/$defs/blob_handle" },
      "default": []
    },
    "groups": {
      "type": "array",
      "description": "Orchestrator-supplied resource groups (§18.5). A tool bound to group:<name> resolves its scope from the matching group.",
      "items": { "$ref": "#/$defs/resource_group" },
      "default": []
    },
    "grants": {
      "type": "array",
      "description": "Access grants over the offered groups (§18.5). No grant means the bound tool is never registered for this ask.",
      "items": { "$ref": "#/$defs/resource_grant" },
      "default": []
    },
    "extra": {
      "description": "Opaque caller metadata, echoed into the trace. Never interpreted by the agent."
    }
  },
  "$defs": {
    "resource_group": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "resources": { "type": "array", "items": { "$ref": "#/$defs/resource_ref" }, "default": [] }
      }
    },
    "resource_ref": {
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        { "properties": { "kind": { "const": "fs_root" }, "path": { "type": "string" } }, "required": ["kind", "path"] },
        { "properties": { "kind": { "const": "blob" }, "handle": { "$ref": "#/$defs/blob_handle" } }, "required": ["kind", "handle"] },
        { "properties": { "kind": { "const": "sqlite" }, "path": { "type": "string" } }, "required": ["kind", "path"] },
        { "properties": { "kind": { "const": "http_host" }, "host": { "type": "string" } }, "required": ["kind", "host"] }
      ]
    },
    "resource_grant": {
      "type": "object",
      "required": ["group", "access"],
      "properties": {
        "group": { "type": "string" },
        "access": { "type": "string", "enum": ["read", "read_write"] }
      }
    },
    "blob_handle": {
      "type": "object",
      "required": ["ref", "media_type"],
      "properties": {
        "ref": { "$ref": "#/$defs/blob_ref" },
        "media_type": {
          "type": "string",
          "description": "IANA media type of the payload."
        },
        "perms": { "$ref": "#/$defs/blob_perms" },
        "name": {
          "type": "string",
          "description": "Suggested file name inside the scratchpad; the host may sanitize it."
        }
      }
    },
    "blob_ref": {
      "type": "object",
      "required": ["kind"],
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "bytes" },
            "base64": { "type": "string" }
          },
          "required": ["kind", "base64"]
        },
        {
          "properties": {
            "kind": { "const": "path" },
            "path": { "type": "string" }
          },
          "required": ["kind", "path"]
        },
        {
          "properties": {
            "kind": { "const": "sha256" },
            "sha256": { "type": "string" }
          },
          "required": ["kind", "sha256"]
        }
      ]
    },
    "blob_perms": {
      "type": "object",
      "required": ["read"],
      "properties": {
        "read": { "type": "boolean" },
        "write": { "type": "boolean", "default": false },
        "execute": { "type": "boolean", "default": false }
      }
    }
  }
}
